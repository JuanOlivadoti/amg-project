{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "API REST autenticada (etapa 5.1). Verifica el JWT, pone app.user_id, y deja que RLS decida (ADR-15/17/18).",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
