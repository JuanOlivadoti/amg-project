# api/.env — plantilla de las variables de la API (portal backend).
#
# En LOCAL: no hace falta ninguna — `npm run dev:server -w api` corre sobre PGlite con un verificador
# de token falso, sin credenciales. Estas variables son para el `npm run serve -w api` de PRODUCCIÓN
# (Railway), que falla cerrado si falta alguna de las obligatorias.
#
# En Railway NO se usa un archivo .env: estas mismas claves se cargan como "Variables" del servicio.
# Esta plantilla es la lista de qué poner. Los valores (secretos) NUNCA van al repo ni al chat.

# ── Obligatorias (sin ellas la API no arranca) ──────────────────────────────────

# Conexión del login `amg_api` (rol app_user, RLS). NO es la de admin de las migraciones.
# Sale de Supabase → Project Settings → Database, y le ponés la contraseña que fijaste con
# `alter role amg_api with password ...` (ver docs/proyecto/12-credenciales.md).
DATABASE_URL_API=postgres://amg_api:LA-PASSWORD@HOST:5432/postgres

# Secreto del JWT de Supabase (HS256), para verificar la firma del token de login.
# Supabase → Project Settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=

# Origen(es) del portal, separados por coma. NO se acepta `*` ni http:// (la API lo rechaza).
# Ej: https://app.tudominio.com  (varios: https://app.tudominio.com,https://admin.tudominio.com)
CORS_ORIGINS=https://app.tudominio.com

# ── Recomendadas (cierran la puerta a tokens de OTRO proyecto Supabase) ──────────

# `iss` esperado del JWT: https://<tu-proyecto>.supabase.co/auth/v1
SUPABASE_JWT_ISS=

# `aud` esperado. Por defecto `authenticated` (lo que emite Supabase). Dejalo vacío si no cambiaste el default.
SUPABASE_JWT_AUD=

# ── La inyecta Railway sola ──────────────────────────────────────────────────────
# PORT — no la pongas a mano; Railway la asigna y el server la lee.
