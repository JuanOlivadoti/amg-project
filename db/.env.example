# db/.env — plantilla para los CLI de DESPLIEGUE de la base (una sola vez, al desplegar).
#
# Estas variables NO las usa ningún proceso en runtime: solo los dos comandos de deploy, corridos a
# mano contra Supabase. Van con conexión de ADMIN (superusuario del proyecto), no con `amg_api`.
#
#   DATABASE_URL_ADMIN=... npm run migrate:deploy -w db
#   DATABASE_URL_ADMIN=... SEED_FRANK_USER_ID=... SEED_JUAN_USER_ID=... npm run seed:demo -w db
#
# Podés exportarlas en la shell en vez de este archivo. Si usás el archivo, `db/.env` está gitignoreado.

# Conexión de ADMIN de Supabase (rol `postgres`): crea roles y es dueña del esquema. Sale de
# Supabase → Project Settings → Database → Connection string (URI). Es la ÚNICA vez que se usa esta
# credencial; la API y el renderizador usan sus logins mínimos.
DATABASE_URL_ADMIN=postgres://postgres:LA-PASSWORD@HOST:5432/postgres

# Los `sub` (UUID) de los usuarios de Frank y Juan en Supabase Auth. Se crean ANTES del seed
# (Authentication → Users → Add user), y se copian sus IDs acá. Solo los usa `seed:demo`.
SEED_FRANK_USER_ID=
SEED_JUAN_USER_ID=
