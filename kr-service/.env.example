# Copiá este archivo a `.env` y completá los valores. NO subas `.env` al repo.

# DataForSEO
# mode=mock → datos ficticios locales, SIN cuenta (default, para empezar ya).
# mode=live → API real (requiere credenciales + base URL).
DATAFORSEO_MODE=mock
# Para 'live': sandbox (ficticio, sin costo) o https://api.dataforseo.com (real).
DATAFORSEO_BASE_URL=https://sandbox.dataforseo.com
DATAFORSEO_LOGIN=tu-login
DATAFORSEO_PASSWORD=tu-password

# LLM — proveedor de generación (seeds/briefs). Autodetecta: OpenAI > Anthropic > mock.
# Forzar con: openai | anthropic | mock
LLM_PROVIDER=

# OpenAI (generación + embeddings para clustering). Recomendado por los embeddings.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (alternativa para generación; NO tiene embeddings propios).
ANTHROPIC_API_KEY=

# Tarifas de los modelos (USD por 1M de tokens) para calcular el costo del run.
# ⚠️ Los defaults del código son APROXIMADOS: confirmalos contra la página de precios
# del proveedor antes de usar el costo en una propuesta comercial.
# LLM_PRICES={"gpt-4o":{"input":2.5,"output":10},"text-embedding-3-small":{"input":0.02,"output":0}}
