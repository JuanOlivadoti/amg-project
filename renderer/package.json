{
  "name": "renderer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Renderizador público multi-tenant (ADR-19): 1 servicio, N dominios. Lee Storyblok en vivo y sirve el HTML de web-builder.",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "serve": "tsx src/server.ts",
    "dev:server": "tsx src/dev-server.ts",
    "demo": "tsx src/demo-server.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "db": "*",
    "hono": "^4.6.14",
    "pg": "^8.22.0",
    "web-builder": "*"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
