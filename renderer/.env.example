# renderer/.env — SOLO para la demo local (renderer/demo-server.ts).
#
# Copiá este archivo a `renderer/.env` y completá los valores. `renderer/.env` está gitignoreado:
# NUNCA se commitea, y las keys no van al chat.
#
# Ojo con la distinción que es de SEGURIDAD, no de trámite:
#   · web-builder usa el token de MANAGEMENT (escribe en el space). NO va acá.
#   · el renderizador usa la Content Delivery API, que tiene sus PROPIOS tokens de LECTURA.
# Los sacás de Storyblok → tu space → Settings → Access Tokens.

# ── Obligatorio ────────────────────────────────────────────────────────────────
# Token "Public" de la CDA: sirve el contenido PUBLICADO. No es un secreto fuerte
# (en un setup normal de Storyblok viaja en el navegador), pero igual va en .env.
STORYBLOK_PUBLIC_TOKEN=

# El id numérico de tu space (el mismo STORYBLOK_SPACE_ID de web-builder/.env).
# Tiene que coincidir con el real: el webhook de invalidación llega con este número.
STORYBLOK_SPACE_ID=

# El dominio de la demo. Puede ser cualquiera (no hace falta comprarlo ni DNS): en
# local se sirve por la cabecera Host. En minúsculas, sin http:// y sin puerto.
DEMO_DOMAIN=bellanapoli.es

# ── Opcional pero recomendado (habilita el Visual Editor) ───────────────────────
# Token "Preview" de la CDA: sirve BORRADORES. Es lo que hace andar el Visual Editor.
# Sin él, la web pública funciona igual; solo no verás el preview en vivo.
STORYBLOK_PREVIEW_TOKEN=

# Región del space. eu (por defecto) | us | ap | ca. Si no sabés, es eu.
STORYBLOK_REGION=eu

# El mismo perfil NAP que se usó al publicar, para que el JSON-LD de la web viva
# coincida con lo publicado. Ruta relativa a renderer/.
BUSINESS_PROFILE_PATH=../web-builder/business-profile.json

# De dónde leer los slugs a anunciar. Por defecto usa el brief aprobado de la
# acción 06. Si no existe, cae al brief.json.
BRIEF_PATH=../kr-service/out/brief.approved.json
