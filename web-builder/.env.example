# Copiá este archivo a `.env` y completá los valores. NO subas `.env` al repo.

# Publicación de la web generada.
# mode=mock  → escribe la story (JSON Storyblok) + preview HTML en out/, SIN cuenta (default).
# mode=storyblok → publica en Storyblok vía Management API (requiere token + space).
WEB_PUBLISH_MODE=mock

# Storyblok (solo para mode=storyblok). ADR-04/ADR-11: un space por cliente.
STORYBLOK_MANAGEMENT_TOKEN=
STORYBLOK_SPACE_ID=
# Región del space: eu (default) | us | ap | ca | cn
STORYBLOK_REGION=eu

# Ruta al brief del Módulo 2 (por default, la salida del spike de kr-service).
KR_BRIEF_PATH=../kr-service/out/brief.json

# Perfil de negocio (NAP + precio + imagen) que enriquece el JSON-LD y la página.
BUSINESS_PROFILE_PATH=./business-profile.json

# Generación de prose (secciones + respuestas FAQ).
# openai → prose real (requiere OPENAI_API_KEY) · mock → texto determinista de relleno.
# Si no se setea, autodetecta: openai si hay key, si no mock.
PROSE_MODE=
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Resiliencia HTTP: timeout por intento y reintentos con backoff (429/5xx se reintentan).
# HTTP_TIMEOUT_MS=30000
# HTTP_RETRIES=3
